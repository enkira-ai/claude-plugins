        const fadeOut = 1 - clamp((localTime - blockDur) / CF, 0, 1);
        const globalOpacity = fadeIn * fadeOut;

        // Ghost path phase (0 - blockDur*0.93 grow, last 7% converge)
        const ghostPhase = clamp(localTime / (blockDur * 0.93), 0, 1);

        // Top formula reveal (slow, 1.5s)
        const formulaT = clamp(localTime / 1.5, 0, 1);
        const formulaReveal = Easing.easeOutCubic(formulaT) * 100;

        // 3-line staggered subtitle — reveals one line at a time
        const subtitleLines = [
