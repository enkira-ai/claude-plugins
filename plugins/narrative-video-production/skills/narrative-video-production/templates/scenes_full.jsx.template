// ── Scene 9: 不约而同 transition (5s, custom chalk-path diagram) ────────────
// Designed via agent-chat with Codex. Replaces a bare formula card with a
// path-family chalk diagram + concise gloss. Candidates fade to 22% (not 0)
// so they linger as a visual prologue for the upcoming 殊途/Σ paths card.
function SceneTransUnreserved() {
  // 6 candidate Bezier paths from 学校 to 山顶 — pre-baked control points
  // (deterministic, not random per-frame) for chalk irregularity.
  const candidates = [
    { c1: [700,  330], c2: [1140, 380] },
    { c1: [720,  500], c2: [1200, 360] },
    { c1: [780,  220], c2: [1100, 600] },
    { c1: [760,  680], c2: [1200, 500] },
    { c1: [700,  370], c2: [1080, 290] },
    { c1: [820,  610], c2: [1180, 450] },
  ];
  // Actual ("the chosen one") path — gentler, central
  const actual = { c1: [740, 470], c2: [1190, 410] };

  const start = { x: 430, y: 590 };
  const peak  = { x: 1490, y: 430 };

  return (
    <Sprite start={TF.transUnresStart} end={TF.transUnresEnd}>
      {({ localTime, duration }) => {
        const fadeIn = clamp(localTime / 0.4, 0, 1);
        const fadeOut = 1 - clamp((localTime - (duration - CF)) / CF, 0, 1);
        const card = fadeIn * fadeOut;

        const zhT = Easing.easeOutCubic(clamp(localTime / 0.6, 0, 1));
        const bridgeT = Easing.easeOutCubic(clamp((localTime - 0.5) / 0.7, 0, 1));
        const diaT = Easing.easeOutCubic(clamp((localTime - 0.7) / 0.4, 0, 1));

        // Formula reveal at 2.8s, gloss at 3.6s
        const formulaT = clamp((localTime - 2.8) / 1.0, 0, 1);
        const formulaReveal = Easing.easeOutCubic(formulaT) * 100;
        const glossT = clamp((localTime - 3.6) / 0.7, 0, 1);

        const fadeCandidatesFactor = 1 - clamp((localTime - 2.0) / 1.0, 0, 1) * 0.78; // → 0.22

        return (
          <div style={{ position: 'absolute', inset: 0, opacity: card }}>
            <ChalkboardBg opacity={0.06}/>

            {/* Top: 不约而同 */}
            <div style={{
              position: 'absolute', top: 110, left: 960,
              transform: `translateX(-50%) translateY(${(1 - zhT) * 14}px)`,
              fontFamily: FONTS.serifCn, fontSize: 130, color: COLORS.chalk,
              letterSpacing: '0.20em', fontWeight: 500,
              textShadow: '0 0 30px rgba(244,238,222,0.22)',
              opacity: zhT,
              whiteSpace: 'nowrap',
            }}>不约而同</div>

            {/* Bridge */}
            <div style={{
              position: 'absolute', top: 280, left: 960,
              transform: 'translateX(-50%)',
              fontFamily: FONTS.serifCn, fontSize: 30, color: COLORS.chalkDim,
              letterSpacing: '0.10em',
              opacity: bridgeT,
              whiteSpace: 'nowrap',
            }}>当年我们各自出游，却都选择了爬山</div>

            {/* SVG path diagram */}
            <svg style={{ position: 'absolute', left: 0, top: 0, pointerEvents: 'none' }}
                 width="1920" height="1080">
              <defs>
                <radialGradient id="dot_glow">
                  <stop offset="0%"   stopColor={COLORS.chalk} stopOpacity="0.7"/>
                  <stop offset="100%" stopColor={COLORS.chalk} stopOpacity="0"/>
                </radialGradient>
              </defs>

              {/* Mountain peak (2 chalk strokes, right side) */}
              <g opacity={diaT * 0.9} style={{ filter: 'drop-shadow(0 0 6px rgba(244,238,222,0.10))' }}>
                <path
                  d={`M ${peak.x - 110} ${peak.y + 160} L ${peak.x} ${peak.y - 18} L ${peak.x + 100} ${peak.y + 130}`}
                  stroke={COLORS.chalkDim}
                  strokeWidth="3.5"
                  fill="none"
                  strokeLinecap="round"
                  strokeLinejoin="round"
                />
                <path
                  d={`M ${peak.x - 30} ${peak.y + 56} L ${peak.x + 8} ${peak.y + 14} L ${peak.x + 36} ${peak.y + 40}`}
                  stroke={COLORS.chalkDim}
                  strokeWidth="2"
                  fill="none"
                  strokeLinecap="round"
                  strokeLinejoin="round"
                  opacity="0.55"
                />
              </g>

              {/* Start dot — 学校 */}
              <g opacity={diaT}>
                <circle cx={start.x} cy={start.y} r="22" fill="url(#dot_glow)"/>
                <circle cx={start.x} cy={start.y} r="7"  fill={COLORS.chalk}/>
                <text x={start.x} y={start.y + 52}
                      textAnchor="middle"
                      fill={COLORS.chalkDim}
                      fontSize="22"
                      fontFamily={FONTS.serifCn}
                      letterSpacing="0.1em">学校</text>
              </g>

              {/* Peak dot — 山顶 */}
              <g opacity={diaT}>
                <circle cx={peak.x} cy={peak.y} r="22" fill="url(#dot_glow)"/>
                <circle cx={peak.x} cy={peak.y} r="7"  fill={COLORS.chalk}/>
                <text x={peak.x} y={peak.y - 28}
                      textAnchor="middle"
                      fill={COLORS.chalkDim}
                      fontSize="22"
                      fontFamily={FONTS.serifCn}
                      letterSpacing="0.1em">山顶</text>
              </g>

              {/* Candidate paths — fade to 22% (don't fully erase) */}
              {candidates.map((p, i) => {
                const startT = 1.0 + i * 0.15;
                const draw = Easing.easeOutCubic(clamp((localTime - startT) / 0.7, 0, 1));
                const d = `M ${start.x} ${start.y} C ${p.c1[0]} ${p.c1[1]}, ${p.c2[0]} ${p.c2[1]}, ${peak.x} ${peak.y}`;
                return (
                  <g key={i} opacity={fadeCandidatesFactor}>
                    {/* dusty layer */}
                    <path
                      d={d}
                      pathLength="100"
                      stroke={COLORS.chalkDim}
                      strokeWidth="5"
                      fill="none"
                      strokeLinecap="round"
                      strokeLinejoin="round"
                      opacity="0.20"
                      style={{ strokeDasharray: 100, strokeDashoffset: 100 * (1 - draw) }}
                    />
                    {/* main stroke */}
                    <path
                      d={d}
                      pathLength="100"
                      stroke={COLORS.chalkDim}
                      strokeWidth="2.2"
                      fill="none"
                      strokeLinecap="round"
                      strokeLinejoin="round"
                      style={{ strokeDasharray: 100, strokeDashoffset: 100 * (1 - draw) }}
                    />
                  </g>
                );
              })}

              {/* Actual path — the "chosen" classical route, white + thicker */}
              {(() => {
                const draw = Easing.easeOutCubic(clamp((localTime - 2.0) / 0.8, 0, 1));
                const brightness = clamp((localTime - 2.0) / 0.8, 0, 1);
                const d = `M ${start.x} ${start.y} C ${actual.c1[0]} ${actual.c1[1]}, ${actual.c2[0]} ${actual.c2[1]}, ${peak.x} ${peak.y}`;
                return (
                  <g>
                    {/* outer glow */}
                    <path
                      d={d}
                      pathLength="100"
                      stroke={COLORS.chalk}
                      strokeWidth="9"
                      fill="none"
                      strokeLinecap="round"
                      strokeLinejoin="round"
                      opacity={brightness * 0.25}
                      style={{ strokeDasharray: 100, strokeDashoffset: 100 * (1 - draw), filter: 'blur(4px)' }}
                    />
                    {/* main bright stroke */}
                    <path
                      d={d}
                      pathLength="100"
                      stroke={COLORS.chalk}
                      strokeWidth="3.8"
                      fill="none"
                      strokeLinecap="round"
                      strokeLinejoin="round"
                      opacity={brightness}
                      style={{ strokeDasharray: 100, strokeDashoffset: 100 * (1 - draw) }}
                    />
                  </g>
                );
              })()}
            </svg>

            {/* Formula δS[路径] = 0 */}
            <div style={{
              position: 'absolute', top: 830, left: 960,
              transform: 'translateX(-50%)',
              fontFamily: FONTS.serifEn, fontStyle: 'italic',
              fontSize: 60, color: COLORS.chalk,
              letterSpacing: '0.04em',
              textShadow: '0 0 22px rgba(244,238,222,0.20)',
              whiteSpace: 'nowrap',
            }}>
              <span style={{
                display: 'inline-block',
                clipPath: `inset(0 ${100 - formulaReveal}% 0 0)`,
                WebkitClipPath: `inset(0 ${100 - formulaReveal}% 0 0)`,
              }}>
                δS<span style={{ fontStyle: 'normal', fontFamily: FONTS.serifCn, padding: '0 0.06em' }}>[路径]</span>
                {' = 0'}
              </span>
            </div>

            {/* Gloss */}
            <div style={{
              position: 'absolute', top: 928, left: 960,
              transform: 'translateX(-50%)',
              fontFamily: FONTS.serifCn, fontSize: 22,
              color: COLORS.chalkDim, letterSpacing: '0.10em',
              opacity: glossT,
              whiteSpace: 'nowrap',
              display: 'flex', alignItems: 'center', gap: 14,
            }}>
              <span style={{
                fontFamily: FONTS.mono,
                letterSpacing: '0.4em', textTransform: 'uppercase',
                fontSize: 18,
              }}>stationary action</span>
              <span style={{ opacity: 0.5 }}>·</span>
              <span style={{ fontStyle: 'italic', fontFamily: FONTS.serifCn }}>
                轻轻改路线，作用量不变
              </span>
            </div>

            <PersistentEntropyChalkFull/>
          </div>
        );
      }}
    </Sprite>
  );
}

