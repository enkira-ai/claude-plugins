// ── Scene 16: 同归 transition + formula morph (5s) ──────────────────────────
// 0.0-0.7s: 同归 reveal (top)
// 0.0-2.5s: ∫𝒟x e^(iS/ℏ) holding then fading
// 1.5-3.5s: scatter glow (radial pulse at center)
// 2.5-4.0s: |ψ⟩ = (|南京⟩ + |美国⟩) / √2 fading in
// 3.5-4.5s: en tag "RE-ENTANGLED · 2026" fades in
// 4.5-5.0s: hold + crossfade out
function SceneTransConverge() {
  return (
    <Sprite start={TF.transConvergeStart} end={TF.transConvergeEnd}>
      {({ localTime, duration }) => {
        const cardOpacity =
          localTime < 0.4
            ? Easing.easeOutCubic(clamp(localTime / 0.4, 0, 1))
            : localTime > duration - CF
              ? 1 - Easing.easeInCubic(clamp((localTime - (duration - CF)) / CF, 0, 1))
              : 1;

        // 同归 reveal — 0.7s
        const zhT = clamp(localTime / 0.7, 0, 1);
        const zhEase = Easing.easeOutCubic(zhT);

        // Formula 1 (path integral) — fully visible 0-1.0s, fading 1.0-2.5s
        const f1Opacity = 1 - clamp((localTime - 1.0) / 1.5, 0, 1);

        // Glow pulse — 1.5-3.5s, peak at 2.5s
        const glowT = clamp((localTime - 1.5) / 2.0, 0, 1);
        const glowAlpha = Math.sin(glowT * Math.PI);

        // Formula 2 (Bell state) — reveal 2.5-4.0s
        const f2T = clamp((localTime - 2.5) / 1.5, 0, 1);
        const f2Reveal = Easing.easeOutCubic(f2T) * 100;

        // EN tag — fade in 3.5-4.3s
        const enT = clamp((localTime - 3.5) / 0.8, 0, 1);

        return (
          <div style={{ position: 'absolute', inset: 0, opacity: cardOpacity }}>
            <ChalkboardBg opacity={0.06}/>

            {/* 同归 */}
            <div style={{
              position: 'absolute', top: 220, left: 960,
              transform: `translateX(-50%) translateY(${(1 - zhEase) * 14}px)`,
              fontFamily: FONTS.serifCn, fontSize: 140, color: COLORS.chalk,
              letterSpacing: '0.20em', fontWeight: 500,
              textShadow: '0 0 30px rgba(244,238,222,0.22)',
              opacity: zhEase,
              whiteSpace: 'nowrap',
            }}>同 归</div>

            <div style={{
              position: 'absolute', top: 470, left: 960,
              transform: 'translateX(-50%)',
              width: 240, height: 1, background: COLORS.chalkDim,
              opacity: zhEase * 0.55,
            }}/>

            {/* Glow scatter */}
            <div style={{
              position: 'absolute', left: 960, top: 580,
              transform: 'translate(-50%, -50%)',
              width: 700, height: 700,
              borderRadius: '50%',
              background: `radial-gradient(circle, rgba(244,238,222,${glowAlpha * 0.18}) 0%, transparent 60%)`,
              opacity: glowAlpha,
              pointerEvents: 'none',
            }}/>

            {/* Formula 1: reunion amplitude (named bra-ket) fading */}
            <div style={{
              position: 'absolute', top: 540, left: 960,
              transform: 'translateX(-50%)',
              fontFamily: FONTS.serifEn, fontStyle: 'italic',
              fontSize: 52, color: COLORS.chalk,
              letterSpacing: '0.04em',
              textShadow: '0 0 24px rgba(244,238,222,0.18)',
              opacity: f1Opacity,
              whiteSpace: 'nowrap',
              filter: f1Opacity < 1 ? `blur(${(1 - f1Opacity) * 3}px)` : 'none',
            }}><ReunionAmplitudeFormulaJsx/></div>

            {/* Formula 2: Bell state — entangled state */}
            <div style={{
              position: 'absolute', top: 600, left: 960,
              transform: 'translateX(-50%)',
              fontFamily: FONTS.serifEn, fontStyle: 'italic',
              fontSize: 80, color: COLORS.chalk,
              letterSpacing: '0.04em',
              textShadow: '0 0 28px rgba(244,238,222,0.22)',
              whiteSpace: 'nowrap',
              opacity: clamp(f2T * 1.2, 0, 1),
            }}>
              <span style={{
                display: 'inline-block',
                clipPath: `inset(0 ${100 - f2Reveal}% 0 0)`,
                WebkitClipPath: `inset(0 ${100 - f2Reveal}% 0 0)`,
              }}>|ψ⟩ = (|南京⟩ + |美国⟩) / √2</span>
            </div>

            {/* EN tag */}
            <div style={{
              position: 'absolute', bottom: 220, left: 960,
              transform: 'translateX(-50%)',
              fontFamily: FONTS.mono, fontSize: 22, color: COLORS.chalkDim,
              letterSpacing: '0.5em', textTransform: 'uppercase',
              opacity: enT * 0.85,
              whiteSpace: 'nowrap',
            }}>RE-ENTANGLED · 2026</div>

            <PersistentEntropyChalkFull/>
          </div>
        );
      }}
    </Sprite>
  );
}

