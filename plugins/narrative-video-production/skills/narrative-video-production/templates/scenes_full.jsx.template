// Storyboard (absolute Stage time, with 0.4s scene-to-scene crossfade):
//   0:00.0 SceneTitleFull             2.5s
//   0:02.5 SceneVideoBoWen1           9.92s — 文博 引子
//   0:12.4 SceneTransitionUnlock      5.0s — 黑板"解锁记忆"
//   0:17.4 SceneVideoChenGongyu      71.87s — OPEN, 找回笔记本
//   1:29.3 SceneBlock1Unlock         14.0s — 笔记本→寝室→古林
//   1:43.3 SceneVideoLiChengdong     15.38s — 诗意"我爱无比"
//   1:58.7 SceneBlock2Memories       30.0s — 共同的回忆
//   2:28.7 SceneVideoYuWanqing       27.6s — 西雅图
//   2:56.3 SceneTransUnreserved       5.0s — 不约而同 + δS=0
//   3:01.3 SceneBlock3Mountains      35.0s — 三川五岳·游学四方
//   3:36.3 SceneVideoZhangWang       38.72s — 波特兰"我爱物理"
//   4:15.0 SceneBlock4Roots          30.0s — 物理之根
//   4:45.0 SceneVideoGuoXing         48.21s — 旧金山
//   5:33.2 SceneTransSeparate         5.0s — 殊途 + Σ_paths e^iS/ℏ
//   5:38.2 SceneBlock5Evolution      28.0s — 路径积分 + ghost paths + ghost photos
//   6:06.2 SceneTransConverge         5.0s — 同归 + ∫𝒟x → |ψ⟩ Bell state morph
//   6:11.2 SceneVideoHuangZhangCheng 29.31s — CLOSE 玩物理永远年轻
//   6:40.5 SceneOutroFinal            8.0s — invariant + 我爱物理 + logos + producer credit
// Total ≈ 6:48

const CF = 0.4; // crossfade overlap between adjacent scenes

const TF = (() => {
  const t = {};
  let c = 0;
  function add(name, dur) {
    t[name + 'Start'] = c;
    t[name + 'End']   = c + dur + CF; // sprite stays mounted through crossfade tail
    t[name + 'Dur']   = dur + CF;
    c += dur;
  }
  add('title',           2.5);
  add('boWen',           9.92);
  add('unlock',          5.0);
  add('chen',           71.87);
  add('block1',         14.0);
  add('li',             15.38);
  add('block2',         30.0);
  add('yu',             27.6);
  add('transUnres',      5.0);  // 不约而同, 1.5 → 3 → 5
  add('block3',         35.0);
  add('zw',             38.72);
  add('block4',         30.0);
  add('guo',            48.21);
  add('transSeparate',   5.0);  // 殊途, 1.5 → 3 → 5
  add('block5',         28.0);
  add('transConverge',   5.0);  // 同归 + formula morph, 3 → 5
  add('hzc',            29.31);
  add('outro',           8.0);  // PHYSICS·INVARIANT + 我爱物理 + 3 logos + producer credit
  t.TOTAL = c;
  t.CF = CF;
  return t;
})();

// ── Helper: flatten a block's subfolder photos into a PhotoBlock list ──────
function flattenBlock(blockKey, subOrder, opts = {}) {
  const { dwell = 1.0 } = opts;
  const out = [];
  const block = PHOTOS[blockKey] || {};
  for (const sub of subOrder) {
    const files = block[sub] || [];
    for (const src of files) out.push({ src, dwell });
  }
  return out;
}

