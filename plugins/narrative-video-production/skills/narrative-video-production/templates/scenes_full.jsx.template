// ── Scene 5: Block 1 (14s, 自定义节奏曲线) ──────────────────────────────────
function SceneBlock1Unlock() {
  const photos = (() => {
    const b1 = PHOTOS.block1;
    const list = [];
    // 1. Trigger (long hold) — iconic laptop
    list.push({ src: '_curated/block1_解锁记忆/笔记本回响/笔记本回响_01.jpg', dwell: 2.5, kenBurns: 'in' });
    // 2. Fast flickers
    const flickers = (b1['笔记本回响'] || []).filter(s => !s.endsWith('笔记本回响_01.jpg'));
    for (const s of flickers.slice(0, 3)) list.push({ src: s, dwell: 0.18, kenBurns: 'flicker' });
    // 3. Decelerating shards
    const shards = [...(b1['寝室回响'] || []), ...(b1['少数人合影（还记得当年吗）'] || [])];
    const N = shards.length;
    const dMin = 0.32, dMax = 1.0;
    for (let i = 0; i < N; i++) {
      const t = N > 1 ? i / (N - 1) : 0;
      const eased = Math.pow(t, 1.5);
      list.push({ src: shards[i], dwell: dMin + (dMax - dMin) * eased });
    }
    // 4. Stable end — 古林联谊
    if (b1['古林联谊'] && b1['古林联谊'][0]) {
      list.push({ src: b1['古林联谊'][0], dwell: 2.0, kenBurns: 'in' });
    }
    return list;
  })();

  return (
    <Sprite start={TF.block1Start} end={TF.block1End}>
      <PhotoBlock photos={photos} bgColor={COLORS.bg} globalFadeOut={CF}/>
      <BlockTitle cn="解锁记忆" sub="找回 20 年前的密码" en="FIND THE PASSWORD" fadeOutDur={CF}/>
      <PersistentEntropyChalkFull/>
    </Sprite>
  );
}

